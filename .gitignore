# Logs
*.log

# WordPress core (installed via Composer)
/wp/
/wp-admin/
/wp-includes/
/wp-*.php
/xmlrpc.php
/index.php
/license.txt
/readme.html

# WordPress config (environment-specific)
wp-config.php
/.htaccess

# WordPress uploads & cache
wp-content/advanced-cache.php
wp-content/backup-db/
wp-content/backups/
wp-content/blogs.dir/
wp-content/cache/
wp-content/upgrade/
wp-content/uploads/
wp-content/upgrade-temp-backup/
wp-content/wp-cache-config.php

# Plugins (managed via Composer)
wp-content/plugins/*
!wp-content/plugins/index.php

# Themes (only keep the custom theme)
wp-content/themes/*
!wp-content/themes/default-theme
!wp-content/themes/index.php

# Built assets (generated by Vite)
wp-content/themes/*/assets/dist/

# Dependencies
/vendor
node_modules/
composer.lock

# Credentials
.env
/auth.json

# OS & editor
.DS_Store
.idea
bash.exe.stackdump

# Build tools
/prepros-*.config
/.gtm/
package-lock.json
*.map

# Misc
/sitemap.xml
/sitemap.xml.gz
wp-snapshot/
