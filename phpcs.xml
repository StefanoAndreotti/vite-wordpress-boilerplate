<?xml version="1.0"?>
<ruleset name="WordPress Theme">
    <description>WordPress coding standards for the theme.</description>

    <!-- Scan only the theme directory -->
    <file>wp-content/themes/default-theme</file>

    <!-- Exclusions -->
    <exclude-pattern>*/assets/dist/*</exclude-pattern>
    <exclude-pattern>*/assets/src/lib/*</exclude-pattern>
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>

    <!-- Use WordPress coding standards -->
    <rule ref="WordPress">
        <!-- Allow short array syntax [] -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
    </rule>

    <!-- PHP version -->
    <config name="testVersion" value="8.2-"/>

    <!-- WordPress version for deprecated function checks -->
    <config name="minimum_supported_wp_version" value="6.0"/>

    <!-- Show progress and sniff codes -->
    <arg value="ps"/>
    <arg name="colors"/>
</ruleset>
